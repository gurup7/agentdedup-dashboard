# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# DynamoDB Table Names
CUSTOMER_TABLE_NAME=CustomerTable
REVIEW_QUEUE_TABLE_NAME=ReviewQueue

# S3 Bucket Names
