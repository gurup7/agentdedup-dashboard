# =============================================================
# AgentDedup Deployment Configuration
# Copy this file to config.env and fill in the values
# =============================================================

# AWS Account & Region
AWS_ACCOUNT_ID=CHANGE_ME
AWS_REGION=us-east-1

# Stack name prefix (all resources will be prefixed with this)
STACK_PREFIX=dedup

# Bedrock Model (ensure this model is enabled in your region)
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# DynamoDB table names
CUSTOMER_TABLE_NAME=dedup-dynamodb-CustomerTable
REVIEW_QUEUE_TABLE_NAME=dedup-dynamodb-ReviewQueue

# S3 bucket names (must be globally unique — change prefix if needed)
BATCH_INPUT_BUCKET=dedup-s3-dedup-batch-input
AUDIT_LOGS_BUCKET=dedup-s3-dedup-audit-logs
BATCH_REPORTS_BUCKET=dedup-s3-dedup-batch-reports

# Dashboard
DASHBOARD_PORT=8501
