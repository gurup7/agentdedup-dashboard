{
  "info": {
    "name": "Customer Data Deduplication API",
    "description": "End-to-end demo collection for the Customer Data Deduplication Prototype.\n\nCovers: new customer registration, duplicate detection, human review, merge actions, and batch dedup.\n\nSetup:\n1. Import the companion environment file (dedup-api-environment.json)\n2. Set {{baseUrl}} to your API Gateway URL\n3. Set {{apiKey}} to your API key\n4. Run requests in folder order for the full demo flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "{{apiKey}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Register Customer",
      "description": "Submit customer records via POST /register. Demonstrates new customer creation, duplicate detection, and LLM-triggered matching.",
      "item": [
        {
          "name": "1a. New Customer (Unique)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Wonderland\",\n  \"email\": \"alice.wonderland@example.com\",\n  \"phone\": \"+14155550100\",\n  \"dateOfBirth\": \"1990-03-15\",\n  \"address\": {\n    \"street\": \"123 Rabbit Hole Lane\",\n    \"city\": \"Portland\",\n    \"state\": \"OR\",\n    \"postalCode\": \"97201\",\n    \"country\": \"US\"\n  },\n  \"sourceSystem\": \"OneCRM\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('New record created', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('new_record');",
                  "  pm.expect(body.customerId).to.be.a('string');",
                  "  // Save for later use",
                  "  pm.collectionVariables.set('newCustomerId', body.customerId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1b. Duplicate Customer (Same Email)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"+14155550101\",\n  \"dateOfBirth\": \"1985-07-22\",\n  \"address\": {\n    \"street\": \"456 Oak Avenue\",\n    \"city\": \"Seattle\",\n    \"state\": \"WA\",\n    \"postalCode\": \"98101\",\n    \"country\": \"US\"\n  },\n  \"sourceSystem\": \"NES\"\n}"
            },
            "description": "Submits a record with the same email as a seeded customer. Expects high-confidence duplicate detection (score >= 0.9) and routing to ReviewQueue."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Duplicate detected', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(['review_pending', 'duplicate_found']).to.include(body.status);",
                  "  if (body.reviewId) {",
                  "    pm.collectionVariables.set('reviewId', body.reviewId);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1c. Partial Match (Similar Name, Triggers LLM)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jonh\",\n  \"lastName\": \"Smyth\",\n  \"email\": \"j.smyth@differentdomain.com\",\n  \"phone\": \"+14155550199\",\n  \"dateOfBirth\": \"1985-07-22\",\n  \"address\": {\n    \"street\": \"456 Oak Ave\",\n    \"city\": \"Seattle\",\n    \"state\": \"WA\",\n    \"postalCode\": \"98101\",\n    \"country\": \"US\"\n  },\n  \"sourceSystem\": \"OneCRM\"\n}"
            },
            "description": "Submits a record with a similar name (typo: Jonh Smyth vs John Smith), same postal code and DOB but different email. Rule-based score should be ambiguous (0.4-0.9), triggering LLM matching."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Potential duplicate or review pending', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(['review_pending', 'new_record', 'duplicate_found']).to.include(body.status);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Review Management",
      "description": "List and inspect pending merge candidates from the ReviewQueue.",
      "item": [
        {
          "name": "2a. List Pending Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array of reviews', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.reviews).to.be.an('array');",
                  "  if (body.reviews.length > 0) {",
                  "    pm.collectionVariables.set('reviewId', body.reviews[0].reviewId);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2b. Get Single Review",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/{{reviewId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "{{reviewId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Review has expected fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.reviewId).to.be.a('string');",
                  "  pm.expect(body.confidenceScore).to.be.a('number');",
                  "  pm.expect(body.status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Merge Actions",
      "description": "Approve or reject merge candidates. Run after folder 2 to have a valid reviewId.",
      "item": [
        {
          "name": "3a. Approve Merge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/{{reviewId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "{{reviewId}}", "approve"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewedBy\": \"data-steward-01\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Merge approved', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('approved');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3b. Reject Merge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/{{reviewId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "{{reviewId}}", "reject"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewedBy\": \"data-steward-01\",\n  \"reason\": \"Records refer to different individuals despite similar names.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Merge rejected', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('rejected');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Batch Dedup",
      "description": "Manually trigger the batch deduplication workflow via Step Functions StartExecution.",
      "item": [
        {
          "name": "4a. Trigger Batch Workflow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{apiKey}}" }
            ],
            "url": {
              "raw": "https://states.{{awsRegion}}.amazonaws.com",
              "protocol": "https",
              "host": ["states", "{{awsRegion}}", "amazonaws", "com"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stateMachineArn\": \"arn:aws:states:{{awsRegion}}:{{awsAccountId}}:stateMachine:dedup-batch-workflow\",\n  \"input\": \"{\\\"bucket\\\": \\\"dedup-batch-input\\\", \\\"key\\\": \\\"test-batch.csv\\\"}\"\n}"
            },
            "description": "Triggers the batch dedup Step Functions workflow. Requires AWS SigV4 auth (configure in Postman Authorization tab with AWS credentials). Alternatively, use the AWS CLI:\n\naws stepfunctions start-execution \\\n  --state-machine-arn arn:aws:states:REGION:ACCOUNT:stateMachine:dedup-batch-workflow \\\n  --input '{\"bucket\": \"dedup-batch-input\", \"key\": \"test-batch.csv\"}'"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Execution started', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.executionArn).to.be.a('string');",
                  "  pm.collectionVariables.set('batchExecutionArn', body.executionArn);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Pre-request script: ensure variables are set",
          "if (!pm.variables.get('baseUrl') || pm.variables.get('baseUrl') === '') {",
          "  console.warn('baseUrl not set — update environment variables before running.');",
          "}",
          "if (!pm.variables.get('apiKey') || pm.variables.get('apiKey') === '') {",
          "  console.warn('apiKey not set — update environment variables before running.');",
          "}"
        ]
      }
    }
  ]
}
